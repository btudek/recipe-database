{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^8.0.0",
    "@prisma/client": "^5.8.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "prisma": "^5.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
