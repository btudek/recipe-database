generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  username     String            @unique
  passwordHash String
  displayName  String?
  avatarUrl    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  comments     Comment[]
  ratings      Rating[]
  userRecipes  UserRecipe[]
  savedRecipes UserSavedRecipe[]
}

model Recipe {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  description     String
  seoDescription  String?
  prepTime        Int
  cookTime        Int
  totalTime       Int?
  yield           Int
  cuisineId       String
  categoryId      String
  primaryKeyword  String?
  metaTitle       String?
  metaDescription String?
  proTips         String?
  storageInfo     String?
  nutrition       Json?
  imageUrl        String?
  status          String            @default("draft")
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  comments        Comment[]
  ingredients     Ingredient[]
  ratings         Rating[]
  category        Category          @relation(fields: [categoryId], references: [id])
  cuisine         Cuisine           @relation(fields: [cuisineId], references: [id])
  relatedFrom     RecipeRelated[]   @relation("RecipeRelatedFrom")
  relatedTo       RecipeRelated[]   @relation("RecipeRelatedTo")
  steps           RecipeStep[]
  versions        RecipeVersion[]
  userRecipes     UserRecipe[]
  savedBy         UserSavedRecipe[]

  @@index([cuisineId])
  @@index([categoryId])
  @@index([status, publishedAt])
  @@index([slug])
}

model RecipeVersion {
  id            String   @id @default(cuid())
  recipeId      String
  versionNumber Int
  title         String
  description   String
  ingredients   Json
  steps         Json
  createdAt     DateTime @default(now())
  recipe        Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Cuisine {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?
  recipes     Recipe[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?
  recipes     Recipe[]
}

model Ingredient {
  id         String  @id @default(cuid())
  recipeId   String
  name       String
  quantity   Float
  unit       String
  notes      String?
  orderIndex Int
  recipe     Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeStep {
  id             String  @id @default(cuid())
  recipeId       String
  stepNumber     Int
  instruction    String
  ingredientRefs String?
  michelinNote   String?
  recipe         Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeRelated {
  id           String @id @default(cuid())
  fromRecipeId String
  toRecipeId   String
  fromRecipe   Recipe @relation("RecipeRelatedFrom", fields: [fromRecipeId], references: [id], onDelete: Cascade)
  toRecipe     Recipe @relation("RecipeRelatedTo", fields: [toRecipeId], references: [id], onDelete: Cascade)

  @@unique([fromRecipeId, toRecipeId])
}

model UserRecipe {
  id             String   @id @default(cuid())
  userId         String
  sourceRecipeId String?
  title          String
  description    String?
  isPublic       Boolean  @default(false)
  isPublished    Boolean  @default(false)
  ingredients    Json
  steps          Json
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sourceRecipe   Recipe?  @relation(fields: [sourceRecipeId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSavedRecipe {
  id       String   @id @default(cuid())
  userId   String
  recipeId String
  savedAt  DateTime @default(now())
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  recipeId   String
  content    String
  isApproved Boolean  @default(true)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  value     Int
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model category {
  id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String   @unique
  slug   String   @unique
  recipe recipe[]
}

model cuisine {
  id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String   @unique
  slug   String   @unique
  recipe recipe[]
}

model diet {
  id     Int      @id @default(autoincrement())
  name   String   @db.VarChar(100)
  slug   String   @db.VarChar(100)
  recipe recipe[]
}

model ingredient {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipe_id   String? @db.Uuid
  name        String
  quantity    Float?
  unit        String?
  notes       String?
  order_index Int?

  @@unique([recipe_id, name, quantity, unit], map: "unique_ingredient")
}

model product {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  upc               String?           @unique @db.VarChar(50)
  brand             String?           @db.VarChar(255)
  name              String            @db.VarChar(500)
  size              String?           @db.VarChar(100)
  category_id       String?           @db.Uuid
  images            String[]
  active_version_id String?           @db.Uuid
  created_at        DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?         @default(now()) @db.Timestamptz(6)
  product_version   product_version[]
  scan_history      scan_history[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model product_score {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_version_id String          @db.Uuid
  score_overall      Int
  label              String          @db.VarChar(20)
  subscores          Json
  drivers_positive   Json?
  drivers_negative   Json?
  improvements       Json?
  confidence_label   String?         @db.VarChar(20)
  model_version      String?         @default("1.0") @db.VarChar(50)
  created_at         DateTime?       @default(now()) @db.Timestamptz(6)
  product_version    product_version @relation(fields: [product_version_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model product_version {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id         String          @db.Uuid
  ingredients_text   String?
  ingredients_parsed Json?
  nutrition_facts    Json?
  serving_size       String?         @db.VarChar(100)
  source_type        String?         @db.VarChar(50)
  source_ref         String?
  confidence         Decimal?        @default(0.5) @db.Decimal(3, 2)
  created_at         DateTime?       @default(now()) @db.Timestamptz(6)
  product_score      product_score[]
  product            product         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model recipe {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String    @unique
  title        String
  description  String?
  prep_time    Int?      @default(0)
  cook_time    Int?      @default(0)
  total_time   Int?      @default(0)
  yield        Int?      @default(4)
  status       String?   @default("draft")
  published_at DateTime? @db.Timestamp(6)
  cuisine_id   String?   @db.Uuid
  category_id  String?   @db.Uuid
  image_url    String?
  diet_id      Int?
  category     category? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cuisine      cuisine?  @relation(fields: [cuisine_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  diet         diet?     @relation(fields: [diet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model recipe_score {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipe_id     String    @db.VarChar(255)
  general_score Int?
  subscores     Json?
  drivers       Json?
  computed_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model recipe_step {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipe_id     String? @db.Uuid
  step_number   Int
  instruction   String
  michelin_note String?

  @@unique([recipe_id, step_number], map: "unique_recipe_step")
}

model scan_history {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.VarChar(255)
  product_id String?   @db.Uuid
  scanned_at DateTime? @default(now()) @db.Timestamptz(6)
  product    product?  @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model user_health_profile {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String    @db.VarChar(255)
  encrypted_payload Bytes?
  consent_version   Int?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
}

model user_preferences {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.VarChar(255)
  prefs      Json?     @default("{}")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}
